{
  "openapi": "3.1.0",
  "info": {
    "title": "ISC Dashboard Backend API",
    "description": "Backend API für das ISC Dashboard mit LDAP-Integration, Benutzer-, Widget- und News-Verwaltung",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000",
      "description": "Lokaler Development Server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Root",
        "description": "API Willkommens-Endpoint",
        "operationId": "root",
        "responses": {
          "200": {
            "description": "Erfolgreiche Antwort",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Prüft, ob die API läuft",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "API ist gesund",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Liste aller Users",
        "description": "Ruft eine Liste aller Benutzer ab mit optionaler Suche und Paginierung",
        "operationId": "list_users",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            },
            "description": "Suchbegriff für username, email, display_name"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Liste der Benutzer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserRead"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "users"
        ],
        "summary": "Neuen User erstellen",
        "operationId": "create_user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Benutzer erfolgreich erstellt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRead"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/{user_id}": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "Einzelnen User abrufen",
        "description": "Ruft einen einzelnen Benutzer ab. Bei aktiviertem LDAP werden aktuelle LDAP-Daten integriert.",
        "operationId": "get_user",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Benutzer gefunden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRead"
                }
              }
            }
          },
          "404": {
            "description": "Benutzer nicht gefunden"
          }
        }
      },
      "put": {
        "tags": [
          "users"
        ],
        "summary": "User aktualisieren",
        "operationId": "update_user",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Benutzer aktualisiert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRead"
                }
              }
            }
          },
          "404": {
            "description": "Benutzer nicht gefunden"
          }
        }
      },
      "delete": {
        "tags": [
          "users"
        ],
        "summary": "User löschen",
        "operationId": "delete_user",
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Benutzer gelöscht"
          },
          "404": {
            "description": "Benutzer nicht gefunden"
          }
        }
      }
    },
    "/api/v1/users/sync-ldap": {
      "post": {
        "tags": [
          "users"
        ],
        "summary": "LDAP-Synchronisation",
        "description": "Startet eine manuelle LDAP-Synchronisation. Synchronisiert alle LDAP-Benutzer mit der Datenbank.",
        "operationId": "sync_ldap_users",
        "responses": {
          "200": {
            "description": "Synchronisation erfolgreich",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "stats": {
                      "type": "object",
                      "properties": {
                        "added": {
                          "type": "integer"
                        },
                        "updated": {
                          "type": "integer"
                        },
                        "deactivated": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "LDAP ist nicht aktiviert"
          },
          "500": {
            "description": "Fehler bei der Synchronisation"
          }
        }
      }
    },
