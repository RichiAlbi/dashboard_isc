            "description": "Widget nicht gefunden"
          }
        }
      },
      "delete": {
        "tags": [
          "widgets"
        ],
        "summary": "Widget löschen",
        "operationId": "delete_widget",
        "parameters": [
          {
            "name": "widget_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
