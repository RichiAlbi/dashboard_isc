        "tags": [
          "settings"
        ],
        "summary": "Globale Einstellungen abrufen",
        "operationId": "get_global_settings",
        "responses": {
          "200": {
            "description": "Globale Einstellungen",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "settings": {
                      "type": "object"
