      "put": {
        "tags": [
          "widgets"
        ],
        "summary": "Bulk-Update von Widgets",
        "operationId": "bulk_update_widgets",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/WidgetUpdate"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Widgets aktualisiert",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WidgetRead"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Fehler beim Update"
          }
        }
      }
    },
    "/api/v1/widgets/{user_id}": {
      "get": {
        "tags": [
          "widgets"
        ],
        "summary": "Widgets eines Users",
        "description": "Ruft alle Widgets eines bestimmten Benutzers ab",
        "operationId": "get_user_widgets",
        "parameters": [
