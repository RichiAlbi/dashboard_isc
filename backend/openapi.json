  "components": {
    "schemas": {
      "UserRead": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "isActive": {
            "type": "boolean",
            "default": true
          },
          "fromLdap": {
            "type": "boolean",
            "default": false
          },
          "lastLdapSync": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "theme": {
            "type": "string",
            "nullable": true,
            "enum": [
              "light",
              "dark",
              "system"
            ]
          }
        },
        "required": [
          "userId"
        ]
      },
      "UserCreate": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "isActive": {
            "type": "boolean",
            "default": true
          },
          "theme": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "UserUpdate": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "isActive": {
            "type": "boolean",
            "nullable": true
          },
          "theme": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "WidgetRead": {
        "type": "object",
        "properties": {
          "widgetId": {
            "type": "string",
            "format": "uuid"
          },
          "target": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        },
        "required": [
          "widgetId",
          "target",
          "icon",
          "title",
          "color"
        ]
      },
      "WidgetCreate": {
        "type": "object",
        "properties": {
          "target": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        },
        "required": [
          "target",
          "icon",
          "title",
          "color"
        ]
      },
      "WidgetUpdate": {
        "type": "object",
        "properties": {
          "widgetId": {
            "type": "string",
            "format": "uuid"
          },
          "target": {
            "type": "string",
            "nullable": true
          },
          "icon": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "color": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "UserWidgetRead": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "widgetId": {
            "type": "string",
            "format": "uuid"
          },
          "target": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "visible": {
            "type": "boolean"
          },
          "config": {
            "type": "object"
          }
        },
        "required": [
          "userId",
          "widgetId",
          "target",
          "icon",
          "title",
          "color",
          "visible",
          "config"
        ]
      },
      "NewsRead": {
        "type": "object",
        "properties": {
          "newsId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "newsId",
          "title",
          "description"
        ]
      },
      "NewsCreate": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "description"
        ]
      },
      "NewsUpdate": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
