# Allgemeine Einstellungen
APP_NAME=dashboard-isc
API_PREFIX=/api
CORS_ORIGINS=*
LOG_LEVEL=INFO

# PostgreSQL Datenbank
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app_user
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db

# SQLAlchemy
DB_ECHO=false

# Password Encryption (AES-256-GCM)
# Der Schlüssel muss exakt 32 Bytes lang sein und Base64-kodiert.
# Generieren mit: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Oder: openssl rand -base64 32
# WICHTIG: Derselbe Schlüssel muss auch im Frontend (VITE_ENCRYPTION_KEY) gesetzt sein!
ENCRYPTION_KEY=

# LDAP Einstellungen
LDAP_ENABLED=false
LDAP_SYNC_ON_STARTUP=false
LDAP_SERVER=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin_password
LDAP_BASE_DN=dc=example,dc=com
LDAP_USER_FILTER=(&(objectCategory=person)(objectClass=user))
LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_USERNAME_ATTR=sAMAccountName
LDAP_EMAIL_ATTR=mail
LDAP_FIRSTNAME_ATTR=givenName
LDAP_LASTNAME_ATTR=sn
LDAP_DISPLAY_NAME_ATTR=displayName
LDAP_ROLE_ATTR=sophomorixRole
LDAP_CLASS_ATTR=sophomorixAdminClass

