# Allgemeine Einstellungen
APP_NAME=dashboard-isc
API_PREFIX=/api
CORS_ORIGINS=*
LOG_LEVEL=INFO

# PostgreSQL Datenbank
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=dashboard_db

# SQLAlchemy
DB_ECHO=false

# LDAP Einstellungen
LDAP_ENABLED=false
LDAP_SYNC_ON_STARTUP=true
LDAP_SERVER=ldaps://your-ldap-server:636
LDAP_BIND_DN=your_bind_dn
LDAP_BIND_PASSWORD=your_bind_password
LDAP_BASE_DN=DC=example,DC=com
LDAP_USER_FILTER=(&(objectClass=person)(objectClass=user))
LDAP_USER_SEARCH_BASE=OU=Users,DC=example,DC=com
LDAP_USERNAME_ATTR=sAMAccountName
LDAP_EMAIL_ATTR=mail
LDAP_FIRSTNAME_ATTR=givenName
LDAP_LASTNAME_ATTR=sn
