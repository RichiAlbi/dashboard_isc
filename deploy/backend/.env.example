# Backend Environment - Production
# Pfad: /opt/disc/backend/.env

# Datenbank
POSTGRES_DB=dashboard_db
POSTGRES_USER=dashboard_prod
POSTGRES_PASSWORD=HIER_SICHERES_PASSWORT_SETZEN

# Backend
DATABASE_URL=postgresql+asyncpg://dashboard_prod:HIER_SICHERES_PASSWORT_SETZEN@db:5432/dashboard_db

# LDAP (falls verwendet)
# LDAP_SERVER=ldap://your-ldap-server
# LDAP_BASE_DN=dc=example,dc=com
# LDAP_BIND_DN=cn=admin,dc=example,dc=com
# LDAP_BIND_PASSWORD=ldap_password

# Sonstiges
# SECRET_KEY=your-secret-key-here
