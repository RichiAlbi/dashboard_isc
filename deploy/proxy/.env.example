# ============================================================
# Dashboard Proxy - Environment Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an
# ============================================================

# -------------------- Session/Security --------------------
# WICHTIG: Generiere sichere Zufallswerte für Produktion!
# z.B.: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
CSRF_SECRET_KEY=your-csrf-secret-key-change-this-in-production

# Session Timeout in Sekunden (Standard: 1 Stunde)
SESSION_MAX_AGE=3600

# -------------------- LDAP Server --------------------
# URI zum LDAP/Active Directory Server
LDAP_URI=ldaps://your-ldap-server.domain.local:636

# Bind DN für Service Account (zum Suchen von Benutzern)
LDAP_BINDDN=CN=ServiceAccount,OU=ServiceAccounts,DC=domain,DC=local

# Passwort für Service Account
LDAP_PASSWORD=your-ldap-bind-password

# Base DN für Benutzersuche
LDAP_BASEDN=DC=domain,DC=local

# -------------------- LDAP Attribute (Active Directory) --------------------
# Für Active Directory:
LDAP_USERNAME_ATTRIBUTE=sAMAccountName
LDAP_FULL_NAME_ATTRIBUTE=cn

# Optional: User Base DN für Bind (Active Directory spezifisch)
# Bei AD wird oft userPrincipalName verwendet: user@domain.local
# Setze dies auf @domain.local wenn Bind mit Email erfolgen soll
# LDAP_USER_BASEDN=@domain.local

# STARTTLS verwenden? (Bei ldaps:// auf False setzen)
LDAP_STARTTLS=False
